# --- GitHub ---
# Fine-grained Personal Access Token with, on the repos you review:
#   Contents: Read-only   +   Pull requests: Read-only
GITHUB_TOKEN=

# --- Google Gemini (writes the walkthrough AND voices it — all free tier) ---
# Free key from https://aistudio.google.com/apikey
GEMINI_API_KEY=
# Optional: narration-writing model. Defaults to gemini-2.5-flash.
GEMINI_MODEL=
# Optional: TTS voice. Defaults to "Kore". Run `npm run voices` for the full list.
GEMINI_TTS_VOICE=
# Optional: TTS model. Defaults to gemini-3.1-flash-tts-preview.
GEMINI_TTS_MODEL=
